{
  "log": {
    "level": "warn",
    "output": "stderr",
    "timestamp": false
  },
  "inbounds": [
    {
      "tag": "vless-ws-in",
      "type": "vless",
      "listen": "0.0.0.0",
      "listen_port": 8080,
      "users": [
        {
          "uuid": "143ba4e0-c1d7-484a-81b5-a96d7f85a574"
        }
      ],
      "multiplex": {
        "enabled": true,
        "padding": true
      },
      "transport": {
        "type": "ws",
        "path": "/gojo/infinity-limitless",
        "max_early_data": 2048,
        "early_data_header_name": "Sec-WebSocket-Protocol"
      }
    }
  ],
  "outbounds": [
    {
      "tag": "direct",
      "type": "direct",
      "domain_strategy": "ipv4_only",
      "fallback_delay": "150ms"
    }
  ],
  "route": {
    "final": "direct",
    "rules": [
      {
        "ip_is_private": true,
        "action": "reject"
      }
    ]
  }
}
